

@model Numerologia.ViewModels.NumerologiaView
@{
    Layout = null;
}



<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Numerologia</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 32px;
            background: #f5f5f5;
            color: #222;
        }

        h1, h2, h3 {
            margin-bottom: 12px;
        }

        .panel {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            max-width: 1000px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(220px, 1fr));
            gap: 16px;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        input {
            padding: 10px;
            font-size: 14px;
        }

        button {
            padding: 10px 14px;
            font-size: 14px;
            cursor: pointer;
            margin-right: 8px;
            margin-top: 8px;
        }

        .validation {
            color: #b00020;
            font-size: 13px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 12px;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }

        pre {
            background: #111;
            color: #eaeaea;
            padding: 16px;
            white-space: pre-wrap;
            word-break: break-word;
        }
    </style>
</head>
<body>
    <div class="panel">
        <h1>Numerologia</h1>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="grid">
                <div class="field">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" />
                    <span asp-validation-for="FirstName" class="validation"></span>
                </div>

                <div class="field">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" />
                    <span asp-validation-for="LastName" class="validation"></span>
                </div>

                <div class="field">
                    <label asp-for="BirthDate"></label>
                    <input asp-for="BirthDate" type="date" />
                    <span asp-validation-for="BirthDate" class="validation"></span>
                </div>

                <div class="field">
                    <label asp-for="TargetDate"></label>
                    <input asp-for="TargetDate" type="date" />
                    <span asp-validation-for="TargetDate" class="validation"></span>
                </div>
            </div>

            <button type="submit">Calcular resumen</button>
        </form>
    </div>

    @if (Model.Resumen is not null)
    {
        <div class="panel">
            <h2>Resumen</h2>
            <table>
                <tr><th>Campo</th><th>Valor</th></tr>
                <tr><td>Life Path</td><td>@Model.Resumen.LifePathNumber</td></tr>
                <tr><td>Expression</td><td>@Model.Resumen.ExpressionNumber</td></tr>
                <tr><td>Challenge Numbers</td><td>@string.Join(", ", Model.Resumen.ChallengeNumbers)</td></tr>
                <tr><td>Pinnacles</td><td>@string.Join(", ", Model.Resumen.Pinnacles)</td></tr>
                <tr><td>Personal Year</td><td>@Model.Resumen.PersonalYear</td></tr>
                <tr><td>Personal Month</td><td>@Model.Resumen.PersonalMonth</td></tr>
                <tr><td>Personal Day</td><td>@Model.Resumen.PersonalDay</td></tr>
                <tr><td>Heredity</td><td>@Model.Resumen.HeredityNumber</td></tr>
                <tr><td>Capsule</td><td>@Model.Resumen.CapsuleNumber</td></tr>
            </table>
        </div>

        <div class="panel">
            <h2>Detalle</h2>

            <button type="button" onclick="callSingle('life-path')">Life Path</button>
            <button type="button" onclick="callSingle('expression')">Expression</button>
            <button type="button" onclick="callSingle('personal-year')">Personal Year</button>
            <button type="button" onclick="callSingle('personal-month')">Personal Month</button>
            <button type="button" onclick="callSingle('personal-day')">Personal Day</button>
            <button type="button" onclick="callSingle('heredity-number')">Heredity</button>
            <button type="button" onclick="callSingle('capsule-number')">Capsule</button>
            <button type="button" onclick="callList('challenge-numbers')">Challenge Numbers</button>
            <button type="button" onclick="callList('pinnacles')">Pinnacles</button>

            <div id="detail-output" style="margin-top: 20px;"></div>
        </div>
    }

    <script>
        function getPayload() {
            return {
                firstName: document.getElementById("FirstName").value,
                lastName: document.getElementById("LastName").value,
                birthDate: document.getElementById("BirthDate").value,
                targetDate: document.getElementById("TargetDate").value || null
            };
        }

        async function postToApi(path) {
            const response = await fetch(`/api/numerologia/${path}`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(getPayload())
            });

            const text = await response.text();

            if (!response.ok) {
                throw new Error(text || `HTTP ${response.status}`);
            }

            return text ? JSON.parse(text) : null;
        }

        async function callSingle(path) {
            try {
                const data = await postToApi(path);
                renderSingle(data);
            } catch (error) {
                renderError(error);
            }
        }

        async function callList(path) {
            try {
                const data = await postToApi(path);
                renderList(data);
            } catch (error) {
                renderError(error);
            }
        }

        function renderSingle(data) {
            const html = `
                <table>
                    <tr><th>Tipo</th><td>${data.type}</td></tr>
                    <tr><th>Numero</th><td>${data.number}</td></tr>
                    <tr><th>Titulo</th><td>${data.title ?? ""}</td></tr>
                    <tr><th>Descripcion</th><td>${data.description ?? ""}</td></tr>
                </table>
                <h3>JSON</h3>
                <pre>${JSON.stringify(data, null, 2)}</pre>
            `;

            document.getElementById("detail-output").innerHTML = html;
        }

        function renderList(data) {
            const rows = data.results.map(item => `
                <tr>
                    <td>${item.number}</td>
                    <td>${item.title ?? ""}</td>
                    <td>${item.description ?? ""}</td>
                </tr>
            `).join("");

            const html = `
                <h3>${data.type}</h3>
                <table>
                    <tr><th>Numero</th><th>Titulo</th><th>Descripcion</th></tr>
                    ${rows}
                </table>
                <h3>JSON</h3>
                <pre>${JSON.stringify(data, null, 2)}</pre>
            `;

            document.getElementById("detail-output").innerHTML = html;
        }

        function renderError(error) {
            document.getElementById("detail-output").innerHTML = `
                <h3>Error</h3>
                <pre>${error.message}</pre>
            `;
        }
    </script>
</body>
</html>
